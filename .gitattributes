# 모든 텍스트 파일은 저장소에 LF로 통일, 체크아웃 시 OS 기본값 사용
* text=auto

# Python / 설정 파일 — LF 강제
*.py    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.env*  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.lock  text eol=lf

# 바이너리
*.png   binary
*.jpg   binary
*.pdf   binary
